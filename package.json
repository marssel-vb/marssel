{
    "name": "@marssel-vb/marssel",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/marssel-vb/marssel.git"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "version": "1.0.6",
    "description": "A modern CSS-in-JS framework that generates instant styles with zero configuration. No build step required, featuring intuitive classes based on standard CSS properties, and including built-in JS components.",
    "main": "dist/marssel.cjs.js",
    "module": "dist/marssel.esm.js",
    "browser": "dist/marssel.umd.js",
    "types": "types/index.d.ts",
    "scripts": {
        "build": "rollup -c rollup.config.js",
        "dev": "rollup -c rollup.config.js -w",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "marssel",
        "css-in-js",
        "css",
        "framework",
        "zero-config",
        "style-instantane",
        "ui",
        "javascript",
        "carousel",
        "modal",
        "tooltip",
        "toast",
        "dropdown",
        "popover",
        "offcanvas"
    ],
    "author": "Valentin Banse",
    "license": "MIT",
    "files": [
        "core/",
        "generators/",
        "managers/",
        "styles/",
        "utils/",
        "index.js",
        "dist/",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "devDependencies": {
        "@rollup/plugin-commonjs": "^28.0.3",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-terser": "^0.4.4",
        "rollup": "^4.40.0"
    }
}
